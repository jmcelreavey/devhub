# ── Core (auto-configured by npm install or install.sh) ──
NOTES_DIR=
# Optional — defaults to REPO_ROOT/docs
# DOCS_DIR=
# Personal data dirs. Default to REPO_ROOT/tasks and REPO_ROOT/collections. Point them
# at a separate (e.g. private) location to keep personal data out of the shared tree.
# TASKS_DIR=
# COLLECTIONS_DIR=
REPO_ROOT=
PORT=1337

# Bind address — 0.0.0.0 for LAN access, 127.0.0.1 for localhost only.
# DEVHUB_BIND_HOST=0.0.0.0
# OPENCHAMBER_HOST=0.0.0.0
# OPENCODE_BIND_HOST=0.0.0.0
# OPENCODE_PORT=1338

# ── PoC Terminal (peer on TERMINAL_PORT, default 1339) ──
# Spawns a local shell rooted at your developer directory. Localhost-only.
# TERMINAL_PORT=1339
# DEVHUB_DEVELOPER_DIR=        # defaults to ~/Developer
# Default shell args are "-l" (login). If a heavy interactive zsh framework
# (e.g. powerlevel10k / ftazsh) deadlocks inside the embedded PTY, override:
# DEVHUB_TERMINAL_ARGS=-f      # skip rc files
# DEVHUB_TERMINAL_SHELL=/bin/bash

# ── Optional: Google Calendar ──
# Configure from http://localhost:1337/setup
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_OAUTH_REDIRECT_URI=

# ── Optional: Jira Cloud ──
# Configure from http://localhost:1337/setup
# JIRA_DOMAIN=
# JIRA_EMAIL=
# JIRA_API_TOKEN=
# NEXT_PUBLIC_JIRA_DOMAIN=

# ── Optional: Datadog ──
# Configure from http://localhost:1337/setup
# DATADOG_API_KEY=
# DATADOG_APPLICATION_KEY=

# ── Optional: Notes in-editor AI (z.ai Coding Plan) ──
# Powers BlockNote AI in the notes editor (/ai slash menu, toolbar stars button).
# Get a key from https://z.ai — never commit real keys; prefer a Z_AI_API_KEY
# field in the 1Password "devhub" item, or copy into .env.local only.
# Z_AI_API_KEY=your-z-ai-api-key
# Z_AI_BASE_URL=https://api.z.ai/api/coding/paas/v4
# Z_AI_MODEL=glm-5-turbo

# ── Optional: BI Infrastructure ──
# AWS_PROFILE=
# CAPI_REPO_PATH=

# ── Optional: ai-tools upstream skills ──
# Local clone of businessinsider/ai-tools; merged into skill sync (read-only in DevHub UI).
# AI_TOOLS_ROOT=/Users/you/Developer/ai-tools
# AI_TOOLS_SYNC=0
# AI_TOOLS_BRANCH=main          # override default branch for upstream skills fetch
# AI_TOOLS_REFRESH_ON_SYNC=0   # skip upstream fetch during skill sync (offline)

# ── 1Password auto-fill (optional) ──
# If the 1Password CLI (op) is installed and signed in, DevHub will
# automatically pull any missing secrets from a "devhub" item on first start
# and cache them into .env.local — no manual copying required.
#
# Setup: create one item in 1Password titled "devhub" and add a field for
# each secret you want auto-filled, named exactly like the env var:
#   Field label  → Env var
#   JIRA_API_TOKEN        → JIRA_API_TOKEN
#   GOOGLE_CLIENT_SECRET  → GOOGLE_CLIENT_SECRET
#   DATADOG_API_KEY       → DATADOG_API_KEY
#   Z_AI_API_KEY          → Z_AI_API_KEY
#   OPENAI_API_KEY        → OPENAI_API_KEY (used by shell/OpenCode tools)
#   … and so on
#
# Install the CLI: https://developer.1password.com/docs/cli/get-started/
#
# Override defaults:
# DEVHUB_OP_ITEM=devhub      # 1Password item title to look up (default: devhub)
# DEVHUB_OP_VAULT=Private    # Pin to a specific vault to avoid ambiguity
# DEVHUB_OP_REFRESH=1        # Force a re-fetch (e.g. after rotating a secret)
# DEVHUB_OP_CACHE=0          # Load into process env without writing secrets to .env.local
# DEVHUB_OP_SYNC_LOCAL=1     # Also pull local-only keys (paths, ports, prefs) from
#                            # 1Password when unset — handy for identical multi-machine
#                            # setups. Off by default; only fills keys not already set,
#                            # so an existing machine's paths are never overwritten.
