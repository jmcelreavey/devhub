# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
.ux-review/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# plugin branding — machine-local whitelabel assets copied by lib/plugins/branding.ts.
# (The generated source files app/plugin-branding.generated.css and
#  lib/plugin-branding.generated.ts are committed empty baselines kept machine-local via
#  `git update-index --skip-worktree`, so they are intentionally NOT ignored here.)
/public/fonts-plugin/
/public/plugin-brand-logo.*
/public/plugin-electron-icon.png
